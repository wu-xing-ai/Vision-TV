# 站点访问密码（必填，不设则不启用访问控制）
PASSWORD=

# 管理员用户名
USERNAME=admin

# 站点名称
SITE_NAME=Vision TV

# 站点公告
ANNOUNCEMENT=

# 存储方式: localstorage | d1 | upstash
NEXT_PUBLIC_STORAGE_TYPE=localstorage

# 是否开放注册: true | false
NEXT_PUBLIC_ENABLE_REGISTER=false

# 图片代理地址
NEXT_PUBLIC_IMAGE_PROXY=

# 豆瓣代理地址
NEXT_PUBLIC_DOUBAN_PROXY=

# 禁用黄色过滤: true | false
NEXT_PUBLIC_DISABLE_YELLOW_FILTER=false

# 搜索最大页数
NEXT_PUBLIC_SEARCH_MAX_PAGE=5

# Upstash Redis（storage_type 为 upstash 时需要）
UPSTASH_URL=
UPSTASH_TOKEN=

# Redis 连接地址（storage_type 为 kv 时需要）
REDIS_URL=

# Docker 环境标识
DOCKER_ENV=false
